generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/prisma/generated/zod"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealType {
  LUNCH
  DINNER
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String        @unique
  clerkId      String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  recipes      Recipe[]
  weeklyMenus  WeeklyMenu[]
  shoppingChecks ShoppingCheck[]
  menuRotations MenuRotation[]
}

model Recipe {
  id           Int                @id @default(autoincrement())
  name         String
  image        String
  video        String?
  instructions String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id])
  userId       Int
  ingredients  RecipeIngredient[]
  menuEntries  MenuEntry[]
}

model WeeklyMenu {
  id          Int         @id @default(autoincrement())
  userId      Int
  name        String?
  isTemplate  Boolean     @default(false)
  hiddenFromCalendar Boolean @default(false)
  tags        String[]    @default([])
  rotationId  Int?
  rotationWeekIndex Int?
  startDate   DateTime?   @db.Date
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])
  rotation    MenuRotation? @relation(fields: [rotationId], references: [id], onDelete: SetNull)
  menuEntries MenuEntry[]
  checks      ShoppingCheck[]
  rotationTemplateRefs MenuRotationTemplate[]
}

model MenuRotation {
  id            Int                    @id @default(autoincrement())
  userId        Int
  name          String?
  description   String?
  startDate     DateTime               @db.Date
  isActive      Boolean                @default(false)
  maxCycles     Int?
  nextWeekIndex Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id])
  templates     MenuRotationTemplate[]
  generatedMenus WeeklyMenu[]

  @@index([userId])
  @@index([userId, isActive])
}

model MenuRotationTemplate {
  id             Int          @id @default(autoincrement())
  rotationId     Int
  templateMenuId Int
  orderIndex     Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rotation       MenuRotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  templateMenu   WeeklyMenu   @relation(fields: [templateMenuId], references: [id])

  @@unique([rotationId, orderIndex])
  @@index([rotationId])
  @@index([templateMenuId])
}

model MenuEntry {
  id           Int        @id @default(autoincrement())
  weeklyMenuId Int
  dayOffset    Int
  mealType     MealType
  recipeId     Int?
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  weeklyMenu   WeeklyMenu @relation(fields: [weeklyMenuId], references: [id])
  recipe       Recipe?    @relation(fields: [recipeId], references: [id])

  @@unique([weeklyMenuId, dayOffset, mealType])
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipes   RecipeIngredient[]
}

model RecipeIngredient {
  recipeId     Int
  ingredientId Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       Decimal
  unit         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@id([recipeId, ingredientId])
}

model ShoppingCheck {
  id            Int       @id @default(autoincrement())
  weeklyMenuId  Int
  userId        Int
  ingredientKey String
  checkedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  weeklyMenu    WeeklyMenu @relation(fields: [weeklyMenuId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@unique([weeklyMenuId, userId, ingredientKey])
}
