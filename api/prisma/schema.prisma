generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/prisma/generated/zod"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealType {
  LUNCH
  DINNER
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String        @unique
  clerkId      String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  recipes      Recipe[]
  weeklyMenus  WeeklyMenu[]
  shoppingChecks ShoppingCheck[]
}

model Recipe {
  id           Int                @id @default(autoincrement())
  name         String
  image        String
  video        String?
  instructions String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id])
  userId       Int
  ingredients  RecipeIngredient[]
  menuEntries  MenuEntry[]
}

model WeeklyMenu {
  id          Int         @id @default(autoincrement())
  userId      Int
  name        String?
  isTemplate  Boolean     @default(false)
  tags        String[]    @default([])
  startDate   DateTime?   @db.Date
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id])
  menuEntries MenuEntry[]
  checks      ShoppingCheck[]
}

model MenuEntry {
  id           Int        @id @default(autoincrement())
  weeklyMenuId Int
  dayOffset    Int
  mealType     MealType
  recipeId     Int?
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  weeklyMenu   WeeklyMenu @relation(fields: [weeklyMenuId], references: [id])
  recipe       Recipe?    @relation(fields: [recipeId], references: [id])

  @@unique([weeklyMenuId, dayOffset, mealType])
}

model Ingredient {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipes   RecipeIngredient[]
}

model RecipeIngredient {
  recipeId     Int
  ingredientId Int
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       Decimal
  unit         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@id([recipeId, ingredientId])
}

model ShoppingCheck {
  id            Int       @id @default(autoincrement())
  weeklyMenuId  Int
  userId        Int
  ingredientKey String
  checkedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  weeklyMenu    WeeklyMenu @relation(fields: [weeklyMenuId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@unique([weeklyMenuId, userId, ingredientKey])
}
